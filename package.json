{
  "name": "stall-revenue-desktop",
  "version": "1.0.0",
  "description": "Stall Revenue System desktop application",
  "author": "Municipal Treasurer's Office - Sta. Catalina",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "desktop": "electron .",
    "client:build": "cd client && npm run build",
    "build": "npm run client:build && electron-builder",
    "dist": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "exceljs": "^3.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.9.1"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "gov.stacatalina.srms",
    "productName": "Stall Revenue System",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/dist/**/*",
      "build/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server/data/stall_rental.db",
        "to": "server/data/stall_rental.db"
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stall Revenue System"
    }
  }
}